generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinica {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)
  rxEnabled Boolean  @default(true)
  // Permisos de módulos adicionales (documentos clínicos, cartola, evoluciones,
  // observaciones). JSON en vez de columnas separadas para poder sumar nuevos
  // módulos sin migraciones futuras — ver src/lib/clinicaModules.ts.
  modules   Json     @default("{\"documentosClinicos\": true, \"cartola\": true, \"evoluciones\": true, \"observaciones\": true}")
  createdAt DateTime @default(now())

  users                      User[]
  chairs                     Chair[]
  patients                   Patient[]
  appointments               Appointment[]
  treatmentPlans             TreatmentPlan[]
  treatmentItems             TreatmentItem[]
  sucursales                 Sucursal[]
  previsiones                Prevision[]
  convenios                  Convenio[]
  prestaciones               Prestacion[]
  administrativeObservations AdministrativeObservation[]
  clinicalDocuments          ClinicalDocument[]
  evolutions                 Evolution[]
  evolutionTemplates         EvolutionTemplate[]
  ledgerMovements            LedgerMovement[]
  workSchedules              WorkSchedule[]

  @@map("clinicas")
}

model User {
  id                         String                      @id @default(uuid())
  email                      String                      @unique
  passwordHash               String
  name                       String
  role                       String                      @default("odontologo")
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  rut                        String?
  clinicaId                  String?
  clinica                    Clinica?                    @relation(fields: [clinicaId], references: [id])
  administrativeObservations AdministrativeObservation[]
  appointments               Appointment[]
  clinicalDocuments          ClinicalDocument[]
  evolutions                 Evolution[]
  ledgerMovements            LedgerMovement[]
  treatmentPlans             TreatmentPlan[]
  workSchedules              WorkSchedule[]
  privacyConsentsSent        Patient[]                   @relation("PrivacyConsentSentBy")

  @@index([clinicaId])
  @@map("users")
}

model Chair {
  id            String         @id @default(uuid())
  number        Int
  name          String?
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  clinicaId     String
  clinica       Clinica        @relation(fields: [clinicaId], references: [id])
  appointments  Appointment[]
  workSchedules WorkSchedule[]

  @@unique([clinicaId, number])
  @@map("chairs")
}

model Patient {
  id                         String                      @id @default(uuid())
  rut                        String
  firstName                  String
  lastName                   String
  phone                      String?
  email                      String?
  birthDate                  DateTime?
  address                    String?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  privacyConsentAt           DateTime?
  privacyConsentStatus       String                      @default("pendiente")
  privacyConsentMethod       String?
  privacyConsentToken        String?                     @unique
  privacyConsentSentAt       DateTime?
  privacyConsentExpiresAt    DateTime?
  privacyConsentSignerName   String?
  privacyConsentSignerRut    String?
  privacyConsentSignerIp     String?
  privacyConsentUserAgent    String?
  privacyConsentSentById     String?
  privacyConsentSentBy       User?                       @relation("PrivacyConsentSentBy", fields: [privacyConsentSentById], references: [id])
  clinicaId                  String
  clinica                    Clinica                     @relation(fields: [clinicaId], references: [id])
  administrativeObservations AdministrativeObservation[]
  appointments               Appointment[]
  clinicalDocuments          ClinicalDocument[]
  evolutions                 Evolution[]
  ledgerMovements            LedgerMovement[]
  treatmentPlans             TreatmentPlan[]

  @@unique([clinicaId, rut])
  @@map("patients")
}

model TreatmentPlan {
  id              String           @id @default(uuid())
  number          Int              @unique @default(autoincrement())
  patientId       String
  professionalId  String?
  status          String           @default("sin_iniciar")
  amount          Int              @default(0)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  convenioId      String?
  name            String?
  paymentMethod   String?
  previsionId     String?
  sucursalId      String?
  clinicaId       String
  clinica         Clinica          @relation(fields: [clinicaId], references: [id])
  ledgerMovements LedgerMovement[]
  items           TreatmentItem[]
  convenio        Convenio?        @relation(fields: [convenioId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  prevision       Prevision?       @relation(fields: [previsionId], references: [id])
  professional    User?            @relation(fields: [professionalId], references: [id])
  sucursal        Sucursal?        @relation(fields: [sucursalId], references: [id])

  @@index([clinicaId])
  @@map("treatment_plans")
}

model TreatmentItem {
  id                      String        @id @default(uuid())
  treatmentPlanId         String
  description             String
  cost                    Int           @default(0)
  completed               Boolean       @default(false)
  createdAt               DateTime      @default(now())
  convenioDiscountPercent Int           @default(0)
  listPrice               Int           @default(0)
  prestacionId            String?
  toothNumber             String?
  clinicaId               String
  clinica                 Clinica       @relation(fields: [clinicaId], references: [id])
  prestacion              Prestacion?   @relation(fields: [prestacionId], references: [id])
  treatmentPlan           TreatmentPlan @relation(fields: [treatmentPlanId], references: [id], onDelete: Cascade)

  @@index([clinicaId])
  @@map("treatment_items")
}

model Sucursal {
  id             String          @id @default(uuid())
  name           String
  address        String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  dimageClinicId String?
  clinicaId      String
  clinica        Clinica         @relation(fields: [clinicaId], references: [id])
  treatmentPlans TreatmentPlan[]

  @@unique([clinicaId, name])
  @@map("sucursales")
}

model Prevision {
  id             String          @id @default(uuid())
  name           String
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  clinicaId      String
  clinica        Clinica         @relation(fields: [clinicaId], references: [id])
  treatmentPlans TreatmentPlan[]

  @@unique([clinicaId, name])
  @@map("previsiones")
}

model Convenio {
  id              String          @id @default(uuid())
  name            String
  discountPercent Int             @default(0)
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  clinicaId       String
  clinica         Clinica         @relation(fields: [clinicaId], references: [id])
  treatmentPlans  TreatmentPlan[]

  @@unique([clinicaId, name])
  @@map("convenios")
}

model Prestacion {
  id        String          @id @default(uuid())
  code      String?
  name      String
  basePrice Int             @default(0)
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  clinicaId String
  clinica   Clinica         @relation(fields: [clinicaId], references: [id])
  items     TreatmentItem[]

  @@unique([clinicaId, code])
  @@map("prestaciones")
}

model Appointment {
  id             String   @id @default(uuid())
  chairId        String
  patientId      String
  startAt        DateTime
  endAt          DateTime
  notes          String?
  status         String   @default("agendada")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  professionalId String?
  type           String   @default("cita")
  clinicaId      String
  clinica        Clinica  @relation(fields: [clinicaId], references: [id])
  chair          Chair    @relation(fields: [chairId], references: [id])
  patient        Patient  @relation(fields: [patientId], references: [id])
  professional   User?    @relation(fields: [professionalId], references: [id])

  @@index([chairId, startAt])
  @@index([professionalId, startAt])
  @@index([clinicaId])
  @@map("appointments")
}

model AdministrativeObservation {
  id             String   @id @default(uuid())
  patientId      String
  professionalId String
  content        String
  createdAt      DateTime @default(now())
  clinicaId      String
  clinica        Clinica  @relation(fields: [clinicaId], references: [id])
  patient        Patient  @relation(fields: [patientId], references: [id])
  professional   User     @relation(fields: [professionalId], references: [id])

  @@index([patientId, createdAt])
  @@index([clinicaId])
  @@map("administrative_observations")
}

model ClinicalDocument {
  id           String   @id @default(uuid())
  patientId    String
  uploadedById String
  category     String
  fileName     String
  fileUrl      String
  resourceType String
  publicId     String
  description  String?
  createdAt    DateTime @default(now())
  clinicaId    String
  clinica      Clinica  @relation(fields: [clinicaId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])

  @@index([patientId, category, createdAt])
  @@index([clinicaId])
  @@map("clinical_documents")
}

model Evolution {
  id             String   @id @default(uuid())
  patientId      String
  professionalId String
  content        String
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  clinicaId      String
  clinica        Clinica  @relation(fields: [clinicaId], references: [id])
  patient        Patient  @relation(fields: [patientId], references: [id])
  professional   User     @relation(fields: [professionalId], references: [id])

  @@index([patientId, createdAt])
  @@index([clinicaId])
  @@map("evolutions")
}

model EvolutionTemplate {
  id        String   @id @default(uuid())
  name      String
  section   String?
  content   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  clinicaId String
  clinica   Clinica  @relation(fields: [clinicaId], references: [id])

  @@index([clinicaId])
  @@map("evolution_templates")
}

model LedgerMovement {
  id              String         @id @default(uuid())
  number          Int            @unique @default(autoincrement())
  patientId       String
  treatmentPlanId String?
  type            String
  debe            Int            @default(0)
  haber           Int            @default(0)
  description     String?
  paymentMethod   String?
  documentNumber  String?
  notes           String?
  registeredById  String
  createdAt       DateTime       @default(now())
  clinicaId       String
  clinica         Clinica        @relation(fields: [clinicaId], references: [id])
  patient         Patient        @relation(fields: [patientId], references: [id])
  registeredBy    User           @relation(fields: [registeredById], references: [id])
  treatmentPlan   TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id])

  @@index([patientId, createdAt])
  @@index([clinicaId])
  @@map("ledger_movements")
}

model WorkSchedule {
  id             String   @id @default(uuid())
  professionalId String
  chairId        String?
  weekday        Int
  startTime      String
  endTime        String
  createdAt      DateTime @default(now())
  clinicaId      String
  clinica        Clinica  @relation(fields: [clinicaId], references: [id])
  chair          Chair?   @relation(fields: [chairId], references: [id])
  professional   User     @relation(fields: [professionalId], references: [id])

  @@index([professionalId, weekday])
  @@index([clinicaId])
  @@map("work_schedules")
}
